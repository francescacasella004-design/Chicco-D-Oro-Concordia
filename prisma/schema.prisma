generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String
  role         String        @default("player")
  createdAt    DateTime      @default(now())
  scoreEvents  ScoreEvent[]  @relation("AssignedBy")
  pendingScoreEvents PendingScoreEvent[] @relation("PendingAssignedBy")
  team         Team?
}

model Competitor {
  id        Int              @id @default(autoincrement())
  name      String
  type      String
  cost      Int              @default(10)
  imageUrl  String?
  scores    ScoreEvent[]
  pendingScores PendingScoreEvent[]
  captainOf Team[]           @relation("Captain")
  teams     TeamCompetitor[]
}

model Team {
  id          Int              @id @default(autoincrement())
  name        String
  userId      Int              @unique
  captainId   Int?
  createdAt   DateTime         @default(now())
  imageUrl    String?
  captain     Competitor?      @relation("Captain", fields: [captainId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  competitors TeamCompetitor[]
}

model TeamCompetitor {
  id           Int        @id @default(autoincrement())
  teamId       Int
  competitorId Int
  competitor   Competitor @relation(fields: [competitorId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, competitorId])
}

model BonusMalus {
  id          Int          @id @default(autoincrement())
  description String
  points      Int
  category    String
  scoreEvents ScoreEvent[]
  pendingScoreEvents PendingScoreEvent[]
}

model ScoreEvent {
  id           Int        @id @default(autoincrement())
  competitorId Int
  bonusMalusId Int
  assignedById Int
  createdAt    DateTime   @default(now())
  assignedBy   User       @relation("AssignedBy", fields: [assignedById], references: [id])
  bonusMalus   BonusMalus @relation(fields: [bonusMalusId], references: [id])
  competitor   Competitor @relation(fields: [competitorId], references: [id])
}

model PendingScoreEvent {
  id            Int        @id @default(autoincrement())
  competitorId  Int
  competitor    Competitor @relation(fields: [competitorId], references: [id])
  bonusMalusId  Int
  bonusMalus    BonusMalus @relation(fields: [bonusMalusId], references: [id])
  assignedById  Int
  assignedBy    User       @relation("PendingAssignedBy", fields: [assignedById], references: [id])
  createdAt     DateTime   @default(now())
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Settings {
  id               String  @id @default("global")
  registrationOpen Boolean @default(true)
  resultsPublished Boolean @default(false)
}

